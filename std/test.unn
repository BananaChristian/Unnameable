func unn_alloc(usize size):ptr opaque
func unn_dealloc(ptr opaque p):void

func main: i32 {
    heap ptr i32 array -> bitcast<ptr i32>(unn_alloc(8))  # 2 i32s
    array[0] = 42
    array[1] = 99
    
    # realloc to 4 i32s
    ptr opaque new_ptr -> realloc(bitcast<ptr opaque>(array), 8, 16)
    
    # cast back and check data survived
    ptr i32 newarr -> bitcast<ptr i32>(new_ptr)
    trace(newarr[0])  # should be 42
    trace(newarr[1])  # should be 99
    
    unn_dealloc(new_ptr)
    return 0
}
